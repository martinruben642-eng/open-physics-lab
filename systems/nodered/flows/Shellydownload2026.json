[
    {
        "id": "tab_shelly_export",
        "type": "tab",
        "label": "Shelly Export zu CSV",
        "disabled": false,
        "info": "Liest alle 15 Minuten die 3 Phasen eines Shelly Pro 3EM aus Home Assistant aus und speichert sie in einer CSV Datei."
    },
    {
        "id": "func_calc_total",
        "type": "function",
        "z": "tab_shelly_export",
        "name": "Daten aufbereiten",
        "func": "let now = new Date();\nlet timestamp = now.toLocaleString('de-CH');\n\n// Werte als Zahlen interpretieren (Fallback 0 falls Fehler)\nlet wertA = Number(msg.phaseA) || 0;\nlet wertB = Number(msg.phaseB) || 0;\nlet wertC = Number(msg.phaseC) || 0;\n\n// Payload für die CSV Node zusammenbauen\nmsg.payload = {\n    \"Zeitstempel\": timestamp,\n    \"Phase A (W)\": wertA,\n    \"Phase B (W)\": wertB,\n    \"Phase C (W)\": wertC,\n    \"Gesamt (W)\": wertA + wertB + wertC\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1110,
        "y": 620,
        "wires": [
            [
                "csv_formatter"
            ]
        ]
    },
    {
        "id": "csv_formatter",
        "type": "csv",
        "z": "tab_shelly_export",
        "name": "Zu CSV formatieren",
        "sep": ";",
        "hdrin": "",
        "hdrout": "once",
        "multi": "one",
        "ret": "\\n",
        "temp": "",
        "skip": "0",
        "strings": true,
        "include_empty_strings": "",
        "include_null_values": "",
        "x": 1320,
        "y": 720,
        "wires": [
            [
                "file_writer"
            ]
        ]
