        "id": "500b08ea96457a5c",
        "type": "function",
        "z": "tab_shelly_export",
        "name": "Daten als CSV formatieren",
        "func": "let timestamp = new Date().toLocaleString('de-DE');\nlet wert = msg.payload;\n\n// Zeile zusammenbauen: Datum/Uhrzeit; Wert mit Zeilenumbruch\nmsg.payload = timestamp + \";\" + wert + \"\\n\";\n\nreturn msg;",
